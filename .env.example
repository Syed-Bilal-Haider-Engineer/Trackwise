# TrackWise Environment Variables
# Copy this file to .env and fill in your values

# ─── Backend ───────────────────────────────────────────────
# Secret key for JWT token signing — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_string

# Your Anthropic API key — required for AI insights and chat
ANTHROPIC_API_KEY=sk-ant-...

# Port the backend listens on
PORT=4000

# SQLite database file path (inside the container)
DB_PATH=/app/data/trackwise.db

# ─── Frontend ──────────────────────────────────────────────
# URL of the backend API, used by Vite at build time
# In Docker Compose dev: http://localhost:4000
# In production: https://api.yourdomain.com
VITE_API_URL=http://localhost:4000
